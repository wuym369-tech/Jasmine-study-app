# 複製此檔為 .env 並填入實際值；.env 不會被提交到 Git
# Copy to .env and fill in; .env is not committed

# ---------- Google Gemini（優先）----------
# 到 Google AI Studio 申請 API key 後填入這裡
VITE_GEMINI_API_KEY=your_google_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-2.5-flash

# ---------- 本機 Qwen（Ollama，備援）----------
# 本機已安裝 Ollama 並執行過：ollama run qwen2.5:14b
# 若用另一台裝置開網頁、Ollama 在電腦上，請改成電腦的 LAN IP，例如：http://192.168.0.116:11434
# VITE_QWEN_LOCAL_URL=http://localhost:11434
# VITE_QWEN_LOCAL_MODEL=qwen2.5:14b

# ---------- 雲端 Qwen（備援）----------
# VITE_QWEN_API_KEY=your_qwen_api_key_here
